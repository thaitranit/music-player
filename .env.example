# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/music-player?retryWrites=true&w=majority

# JWT Secret for authentication (generate a random strong string)
JWT_SECRET=your-super-secret-random-key-here-min-32-characters

# Node environment (development or production)
NODE_ENV=production

# Server port
PORT=5000
